PORT=8000
JWT_SECRET=change-me-in-production-make-it-long-and-random
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d
DATABASE_URL=postgresql://signable:secret@postgres:5432/signable
PROCESSOR_URL=http://processor:8001
# Redis / BullMQ
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Set QUEUES_INLINE=true to run jobs synchronously without Redis (dev fallback)
QUEUES_INLINE=false
BULL_BOARD_ENABLED=false
BULL_COMPLETED_RETAIN=500
BULL_FAILED_RETAIN=5000
STORAGE_ROOT=storage
STORAGE_URL_BASE=http://localhost:8000/api/v1/files
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
EMAIL_ENABLED=false
# EMAIL_PROVIDER: console | smtp | sendgrid | postmark
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@signable.com
# SMTP (when EMAIL_PROVIDER=smtp)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
# SendGrid (when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=
# Postmark (when EMAIL_PROVIDER=postmark)
POSTMARK_SERVER_TOKEN=
MAX_UPLOAD_BYTES=52428800
