// Prisma schema for SignAble — e-signature platform.
// All models managed here. Migration applied via `prisma migrate dev`.

generator client {
  provider      = "prisma-client-js"
  // Cover every runtime we deploy to:
  //   native                       — local dev (darwin / linux glibc)
  //   linux-musl-openssl-3.0.x     — Alpine-based Docker (our Dockerfile)
  //   debian-openssl-3.0.x         — Render/Railway native Node builders (Debian)
  //   debian-openssl-1.1.x         — older Debian runtimes (defensive)
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String
  passwordHash String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())

  documents Document[]
  envelopes Envelope[]
  webhookSubscriptions WebhookSubscription[]

  @@map("users")
}

model Document {
  id              String         @id @default(uuid())
  userId          String
  filename        String
  storageKey      String
  pageCount       Int            @default(0)
  pageDimensions  Json?          // Array<{ pageNumber: number; width: number; height: number }> in PDF points
  status          DocumentStatus @default(PENDING)
  errorMessage    String?
  createdAt       DateTime       @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  envelopes Envelope[]
  envelopeAttachments EnvelopeDocument[]

  @@index([userId])
  @@map("documents")
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model Envelope {
  id               String         @id @default(uuid())
  userId           String
  documentId       String
  title            String
  message          String?
  status           EnvelopeStatus @default(DRAFT)
  signingOrder     SigningOrder   @default(SEQUENTIAL)
  /// Signed document PDF — original pages with signature overlays.
  /// No certificate of completion. Certificate stored separately.
  signedStorageKey      String?
  /// Certificate of Completion PDF — multi-page audit trail. Separated
  /// from the signed document so download surface can offer each
  /// independently (per DocuSign behaviour).
  certificateStorageKey String?
  /// Renderer version stamped at build time. Lets the download path
  /// detect stale outputs (older renderer, missing new format, etc.)
  /// and rebuild inline. Null for legacy envelopes signed before
  /// versioning existed.
  signedPdfVersion      Int?
  createdAt        DateTime       @default(now())
  sentAt           DateTime?
  completedAt      DateTime?
  expiresAt        DateTime?

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  document    Document         @relation(fields: [documentId], references: [id])
  recipients  Recipient[]
  fields      SignatureField[]
  auditEvents AuditEvent[]
  attachedDocuments EnvelopeDocument[]

  @@index([userId])
  @@index([status])
  @@map("envelopes")
}

/// Join table for extra documents attached to an envelope beyond the
/// primary documentId. Primary doc drives the signing pipeline today;
/// extras travel with envelope for sender reference and future bundling.
model EnvelopeDocument {
  envelopeId String
  documentId String
  orderIndex Int      @default(0)
  attachedAt DateTime @default(now())

  envelope Envelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([envelopeId, documentId])
  @@index([envelopeId])
  @@index([documentId])
  @@map("envelope_documents")
}

enum EnvelopeStatus {
  DRAFT
  SENT
  IN_PROGRESS
  COMPLETED
  VOIDED
  EXPIRED
}

enum SigningOrder {
  SEQUENTIAL
  PARALLEL
}

model Recipient {
  id            String          @id @default(uuid())
  envelopeId    String
  email         String
  name          String
  orderIndex    Int             @default(0)
  role          RecipientRole   @default(SIGNER)
  status        RecipientStatus @default(PENDING)
  signingToken  String          @unique @default(cuid())
  signedAt      DateTime?
  declinedAt    DateTime?
  declineReason String?
  ipAddress     String?

  /// Adopted signature image (base64 data URL). Captured once via
  /// the Adopt Your Signature modal, then auto-applied to every
  /// SIGNATURE field on click. Stored on the recipient so the same
  /// style persists across sessions if the signer returns.
  adoptedSignature  String?
  /// Adopted initials image (base64 data URL). Mirrors
  /// adoptedSignature for INITIALS fields.
  adoptedInitials   String?
  /// Full name the signer adopted (may differ from `name` set by the
  /// sender). Used to render the adopted-style preview in the modal.
  adoptedFullName   String?
  /// Adopted initials text (e.g. "DS"). Optional override.
  adoptedInitialsText String?
  /// First time the recipient adopted a signature in any session.
  /// Drives audit + analytics; null until adoption happens.
  adoptedAt         DateTime?

  envelope Envelope         @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  fields   SignatureField[]

  @@index([envelopeId])
  @@map("recipients")
}

enum RecipientRole {
  SIGNER
  CC
  VIEWER
}

enum RecipientStatus {
  PENDING
  VIEWED
  SIGNED
  DECLINED
}

model SignatureField {
  id          String    @id @default(uuid())
  envelopeId  String
  recipientId String
  pageNumber  Int
  xPct        Float
  yPct        Float
  widthPct    Float
  heightPct   Float
  fieldType   FieldType
  required    Boolean   @default(true)
  /// Tile label from the palette (e.g. "Name", "Email"). Stays metadata —
  /// backend doesn't act on it but the editor needs it to round-trip
  /// the user's choice when reloading a draft.
  label       String?
  /// Disables signer interaction. The chip still renders + the value
  /// (pre-filled by sender) is preserved on submit.
  readOnly    Boolean   @default(false)
  value       String?
  options     Json?     // DROPDOWN: { choices: string[] }; CHECKBOX: { label?: string }; TEXT: { placeholder?: string }; null otherwise
  signedAt    DateTime?

  envelope  Envelope  @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  recipient Recipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([envelopeId])
  @@index([recipientId])
  @@map("signature_fields")
}

enum FieldType {
  SIGNATURE
  INITIALS
  DATE
  TEXT
  DROPDOWN
  CHECKBOX
}

model AuditEvent {
  id         String         @id @default(uuid())
  envelopeId String
  eventType  AuditEventType
  actorEmail String
  metadata   Json           @default("{}")
  ipAddress  String?
  createdAt  DateTime       @default(now())

  envelope Envelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)

  @@index([envelopeId])
  @@map("audit_events")
}

enum AuditEventType {
  ENVELOPE_CREATED
  ENVELOPE_SENT
  ENVELOPE_RESENT
  DOCUMENT_VIEWED
  RECIPIENT_SIGNED
  RECIPIENT_DECLINED
  ENVELOPE_COMPLETED
  ENVELOPE_VOIDED
}

model WebhookSubscription {
  id          String   @id @default(uuid())
  userId      String
  url         String
  secret      String
  events      String[] // AuditEventType values, empty = all
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  lastFiredAt DateTime?
  failureCount Int     @default(0)

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId])
  @@map("webhook_subscriptions")
}

model WebhookDelivery {
  id             String   @id @default(uuid())
  subscriptionId String
  eventType      String
  payload        Json
  responseStatus Int?
  responseBody   String?
  attempt        Int      @default(1)
  succeeded      Boolean  @default(false)
  createdAt      DateTime @default(now())

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("webhook_deliveries")
}
